@inproceedings{Nagaoka2010a,
abstract = {This paper describes the mathematical modeling and the propulsive characteristics of a novel robot driven by Archimedean screw mechanisms, named Screw Drive Rover. For secure locomotion on soft soil, the proposed rover would become one of the good solutions because of its robustness to slipping and getting stuck in the soil. Furthermore, the rover is expected to move in various directions by using the dual screw units. However, the interaction between such screw unit and the surrounding soil is quite complicated and remains undefined. So, this paper attempts to model the tractive effort of the rover on the soil. The mathematical modeling is newly developed based upon terramechanics, addressing soil-vehicle interactive mechanics. Finally, the validity of the proposed model is demonstrated by simulation analyses.},
annote = {$\backslash$cite{\{}Nagaoka2010{\}} utilizes terramechanics to model the tractive effort. A relationship between translational traction and slip of screws is presented. Dugoff et al studied this as a function of screw geometry, load, and velocity.

Contact stresses are utilized to build locomotion models. Variables such as normal stress, shear stress, and shear displacement of soil, among others, are used to build a locomotion model. In simulated results, positive correlation between tractive effort and slip in the longitudinal direction. It also found greater tractive effort with greater amount of sinkage of the screw, although this isn't explored in detail.},
author = {Nagaoka, Kenji and Otsuki, Masatsugu and Kubota, Takashi and Tanaka, Satoshi},
booktitle = {IEEE/RSJ 2010 Int. Conf. Intell. Robot. Syst. IROS 2010 - Conf. Proc.},
doi = {10.1109/IROS.2010.5651010},
file = {:Users/d/Documents/Mendeley Desktop/Nagaoka et al/2010/Nagaoka et al. - 2010 - Terramechanics-based propulsive characteristics of mobile robot driven by Archimedean screw mechanism on soft so.pdf:pdf},
isbn = {9781424466757},
issn = {2153-0858},
title = {{Terramechanics-based propulsive characteristics of mobile robot driven by Archimedean screw mechanism on soft soil}},
year = {2010}
}
