@article{Sutherland2017,
abstract = {Salps are marine invertebrates comprising multiple jet-propelled swimming units during a colonial life-cycle stage. Using theory, we show that asynchronous swimming with multiple pulsed jets yields substantial hydrodynamic benefit due to the production of steady swimming velocities, which limit drag. Laboratory comparisons of swimming kinematics of aggregate salps (Salpa fusiformis and Weelia cylindrica) using high-speed video supported that asynchronous swimming by aggregates results in a smoother velocity profile and showed that this smoother velocity profile is the result of uncoordinated, asynchronous swimming by individual zooids. In situ flow visualizations of W. cylindrica swimming wakes revealed that another consequence of asynchronous swimming is that fluid interactions between jet wakes are minimized. Although the advantages of multi-jet propulsion have been mentioned elsewhere, this is the first time that the theory has been quantified and the role of asynchronous swimming verified using experimental data from the laboratory and the field.},
author = {Sutherland, Kelly R. and Weihs, Daniel},
doi = {10.1098/rsif.2017.0298},
file = {:Users/d/Documents/Mendeley Desktop/Sutherland, Weihs/2017/Sutherland, Weihs - 2017 - Hydrodynamic advantages of swimming by salp chains.pdf:pdf},
issn = {17425662},
journal = {J. R. Soc. Interface},
keywords = {efficiency,locomotion,multi-jet,pelagic tunicate,propulsion},
number = {133},
pages = {20170298},
pmid = {28768881},
title = {{Hydrodynamic advantages of swimming by salp chains}},
volume = {14},
year = {2017}
}
@phdthesis{Park2006,
abstract = {In the field of robotics, there is a growing need to provide robots with the ability to interact with complex and unstructured environments. Operations in such environments pose significant challenges in terms of sensing, planning, and control. In particular, it is critical to design control algorithms that account for the dynamics of the robot and environment at multiple contacts. The work in this thesis focuses on the development of a control framework that addresses these issues. The approaches are based on the operational space control framework and estimation methods. By accounting for the dynamics of the robot and environment, modular and systematic methods are developed for robots interacting with the environment at multiple locations. The proposed force control approach demonstrates high performance in the presence of uncertainties. Building on this basic capability, new control algorithms have been developed for haptic teleoperation, multi-contact interaction with the environment, and whole body motion of non-fixed based robots. These control strategies have been experimentally validated through simulations and implementations on physical robots. The results demonstrate the effectiveness of the new control structure and its robustness to uncertainties. The contact control strategies presented in this thesis are expected to contribute to the needs in advanced controller design for humanoid and other complex robots interacting with their environments.},
author = {Park, J.},
booktitle = {Control},
file = {:Users/d/Documents/Mendeley Desktop/Park/2006/10.1.1.126.6622.pdf:pdf},
isbn = {0-542-57134-X},
number = {March},
pages = {149},
title = {{Control Strategies for Robots in Contact}},
url = {http://portal.acm.org/citation.cfm?id=1168372},
year = {2006}
}
@article{Kim2012,
abstract = {This paper describes the development of a biomimetic swimming robot$\backslash$nbased on the locomotion of a marine turtle. To realize the smooth, soft$\backslash$nflapping motions of this type of turtle, a novel actuator was also$\backslash$ndeveloped, using a smart soft composite (SSC) structure that can$\backslash$ngenerate bending and twisting motions in a simple, lightweight$\backslash$nstructure. The SSC structure is a composite consisting of an active$\backslash$ncomponent to generate the actuation force, a passive component to$\backslash$ndetermine the twisting angle of the structure, and a matrix to combine$\backslash$nthe components. The motion of such a structure can be designed by$\backslash$nspecifying the angle between a filament of the scaffold structure and a$\backslash$nshape-memory alloy (SMA) wire. The bending and twisting motion of the$\backslash$nSSC structure is explained in terms of classical laminate theory, and$\backslash$ncross-ply and angled-ply structures were fabricated to evaluate its$\backslash$nmotion. Finally, the turtle-like motion of a swimming robot was realized$\backslash$nby employing a specially designed SSC structure. To mimic the posterior$\backslash$npositive twisting angle of a turtle's flipper during the upstroke, the$\backslash$nSMA wire on the upper side was offset, and a positive ply-angled$\backslash$nscaffold was used. Likewise, for the anterior negative twisting angle of$\backslash$nthe flipper during the downstroke, an offset SMA wire on the lower side$\backslash$nand a positive ply-angled scaffold were also required. The fabricated$\backslash$nflipper's length is 64.3 mm and it realizes 55 mm bending and 24 degrees$\backslash$ntwisting. The resulting robot achieved a swimming speed of 22.5 mm$\backslash$ns(-1).},
author = {Kim, Hyung Jung and Song, Sung Hyuk and Ahn, Sung Hoon},
doi = {10.1088/0964-1726/22/1/014007},
file = {:Users/d/Documents/Mendeley Desktop/Kim, Song, Ahn/2013/Kim, Song, Ahn - 2013 - A turtle-like swimming robot using a smart soft composite (SSC) structure.pdf:pdf},
isbn = {0964-1726},
issn = {09641726},
journal = {Smart Mater. Struct.},
number = {1},
title = {{A turtle-like swimming robot using a smart soft composite (SSC) structure}},
url = {http://iopscience.iop.org/article/10.1088/0964-1726/22/1/014007/pdf},
volume = {22},
year = {2013}
}
