@article{Seraji2002,
abstract = {This paper presents a new strategy for behavior-based navigation$\backslash$nof field mobile robots on challenging terrain, using a fuzzy logic$\backslash$napproach and a novel measure of terrain traversability. A key feature of$\backslash$nthe proposed approach is real-time assessment of terrain characteristics$\backslash$nand incorporation of this information in the robot navigation strategy.$\backslash$nThree terrain characteristics that strongly affect its traversability,$\backslash$nnamely, roughness, slope, and discontinuity, are extracted from video$\backslash$nimages obtained by on-board cameras. This traversability data is used to$\backslash$ninfer, in real time, the terrain Fuzzy Rule-Based Traversability Index,$\backslash$nwhich succinctly quantifies the ease of traversal of the regional$\backslash$nterrain by the mobile robot. A new traverse-terrain behavior is$\backslash$nintroduced that uses the regional traversability index to guide the$\backslash$nrobot to the safest and the most traversable terrain region. The$\backslash$nregional traverse-terrain behavior is complemented by two other$\backslash$nbehaviors, local avoid-obstacle and global seek-goal. The$\backslash$nrecommendations of these three behaviors are integrated through$\backslash$nadjustable weighting factors to generate the final motion command for$\backslash$nthe robot. The weighting factors are adjusted automatically, based on$\backslash$nthe situational context of the robot. The terrain assessment and robot$\backslash$nnavigation algorithms Are implemented on a Pioneer commercial robot and$\backslash$nfield-test studies are conducted. These studies demonstrate that the$\backslash$nrobot possesses intelligent decision-making capabilities that are$\backslash$nbrought to bear in negotiating hazardous terrain conditions during the$\backslash$nrobot motion},
author = {Seraji, Homayoun and Howard, Ayanna},
doi = {10.1109/TRA.2002.1019461},
file = {:Users/d/Documents/Mendeley Desktop/Seraji, Howard/2002/IEEE{\_}2002{\_}TRA{\_}001.pdf:pdf},
isbn = {1042-296X},
issn = {1042296X},
journal = {IEEE Trans. Robot. Autom.},
keywords = {Behavior-based navigation,Fuzzy logic,Mobile robots,Robot navigation,Rough terrain,Sensor-based navigation,Traversability},
number = {3},
pages = {308--321},
title = {{Behavior-based robot navigation on challenging terrain: A fuzzy logic approach}},
volume = {18},
year = {2002}
}
