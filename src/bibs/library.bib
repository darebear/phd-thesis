@article{EPA2015a,
abstract = {Nutrient pollution, defined as excess amounts of nitrogen and phosphorus in aquatic systems, is one$\backslash$r$\backslash$nof the leading causes of water quality impairment in the United States. This report compiles current$\backslash$r$\backslash$ninformation regarding the costs of nutrient pollution. Such costs may be of two broad types. Some$\backslash$r$\backslash$ncosts are associated with reducing nutrient pollution at its sources. Other costs are associated with$\backslash$r$\backslash$nthe impacts of nutrient pollution in the environment. The latter category of costs is referred to as$\backslash$r$\backslash$n“external costs” or “externalities,” because they are “external” to the owners of the farms,$\backslash$r$\backslash$nbusinesses, or facilities that generate them.$\backslash$r$\backslash$nThe data in this compilation were collected from a range of sources including published, peerreviewed$\backslash$r$\backslash$njournals, government-funded research and reports, academic studies and other data$\backslash$r$\backslash$nsources that met data quality objectives and procedures set forth in this report as described in the$\backslash$r$\backslash$nMethods section. This report provides users with a collection of other researchers' data from 2000$\backslash$r$\backslash$nthrough 2012 as well as references to the literature cited. The U.S. Environmental Protection$\backslash$r$\backslash$nAgency's (EPA's) intent is to provide information that users can evaluate and use to form their own$\backslash$r$\backslash$nconclusions about appropriate management actions for controlling nutrient pollution in specific$\backslash$r$\backslash$nwatersheds and waterbodies. Of course, readers should use caution and careful judgment in applying$\backslash$r$\backslash$nthese results, as circumstances are rarely the same from one context to another. Moreover, as the$\backslash$r$\backslash$nreport notes, not all estimates of monetary impacts can be directly translated into economically$\backslash$r$\backslash$nmeaningful cost estimates.$\backslash$r$\backslash$nCost is a major factor in the management and control of nutrient pollution. External costs – costs$\backslash$r$\backslash$nborne by the public more generally – associated with the impacts from uncontrolled or undercontrolled$\backslash$r$\backslash$nnutrient pollution and delayed action are important considerations. The adverse biological$\backslash$r$\backslash$nand ecological effects of nutrient pollution can result in economic losses across multiple industries$\backslash$r$\backslash$nand economic sectors. Managing and controlling nutrient pollution must also include consideration$\backslash$r$\backslash$nof the costs associated such actions, including the development, implementation, and enforcement$\backslash$r$\backslash$nof pollution control plans, wastewater treatment plant upgrades, municipal stormwater controls,$\backslash$r$\backslash$nagricultural best management practices, homeowner septic system improvements, and other actions.$\backslash$r$\backslash$nAlthough it may not be appropriate to directly compare the costs of controlling nutrients to the$\backslash$r$\backslash$neconomic impacts associated with nutrient pollution because the studies vary in their analyses,$\backslash$r$\backslash$nmethodologies, starting conditions and initial assumptions, the document will help users to$\backslash$r$\backslash$nunderstand the substantial economic costs of not controlling nutrient pollution. The data and$\backslash$r$\backslash$ninformation compiled for this report are instructive in that they provide relative order of magnitude$\backslash$r$\backslash$nestimates appropriate for screening or feasibility analyses, and can be used to add perspective to the$\backslash$r$\backslash$ncosts of not implementing controls. The information in this report may inform state, tribal, and local$\backslash$r$\backslash$nprocesses to develop policies and tools to reduce nutrient pollution. The information suggests that$\backslash$r$\backslash$nnitrogen and phosphorus may be expensive to control after they are released to the environment.$\backslash$r$\backslash$nPreventing them from entering the system is potentially a more cost-effective strategy for addressing$\backslash$r$\backslash$nnutrient pollution and its impacts.},
author = {EPA},
doi = {EPA 820-F-15-096},
file = {:Users/d/Documents/Mendeley Desktop/EPA/2015/nutrient-economics-report-2015.pdf:pdf},
isbn = {EPA 820-F-15-096},
journal = {EPA 820-F-15-096},
number = {May},
title = {{A Compilation of Cost Data Associated with the Impacts and Control of Nutrient Pollution}},
url = {http://www2.epa.gov/sites/production/files/2015-04/documents/nutrient-economics-report-2015.pdf},
year = {2015}
}
